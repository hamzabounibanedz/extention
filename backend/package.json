{
  "name": "@delivery-tool/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rimraf dist tsconfig.tsbuildinfo && tsc",
    "start": "node dist/main.js",
    "dev": "tsx watch src/main.ts",
